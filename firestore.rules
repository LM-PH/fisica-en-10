rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /preguntas/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /usuarios/{uid} {
      allow read, create, update, delete: if true;
    }
    match /partidas/{id} {
      allow read: if true;
      allow create: if true;
    }
  }
}